# API base URL for frontend -> backend communication.
# Use /api when frontend and backend are on same host (with proxy/reverse proxy).
# Use full URL in split deployments, e.g. https://your-backend-domain/api
VITE_API_BASE_URL=/api

# Optional explicit SSE stream endpoint.
# Example: https://your-backend-domain/api/events/stream
# VITE_EVENTS_STREAM_URL=/api/events/stream

# Optional request timeout override in milliseconds.
VITE_API_TIMEOUT_MS=15000

# Dev server proxy target (used by vite.config.js)
VITE_DEV_BACKEND_URL=http://localhost:8000
