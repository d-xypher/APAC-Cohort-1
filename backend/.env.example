# CASCADE backend environment template
# Copy this file to backend/.env and fill in values.

APP_ENV=development
PORT=8000
CORS_ORIGINS=http://localhost:5173

# Local SQLite by default; set PostgreSQL URL in cloud.
DATABASE_URL=sqlite:///./cascade.db

# LLM key used by backend/agents/orchestrator.py
GEMINI_API_KEY=

# Google Calendar OAuth
# Download Desktop OAuth client JSON and place it at this path.
GOOGLE_CREDENTIALS_PATH=backend/credentials.json
# Token will be created after first successful auth.
GOOGLE_TOKEN_PATH=backend/token.json

# Optional values retained for future auth flows
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback
